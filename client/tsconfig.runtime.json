{
	"compilerOptions": {
		"composite": true,
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"allowJs": false,
		"noEmit": true,
		"strict": false,
		"skipLibCheck": true,
		"lib": ["DOM", "DOM.Iterable", "ES2021"]
	},
	"include": [
		"runtime.ts",
		"runtime/**/*.ts",
		"vendor/**/*.ts",
		"types/**/*.d.ts"
	],
	"exclude": ["node_modules", "../node_modules"]
}
