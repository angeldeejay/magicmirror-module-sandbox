{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": false,
		"noEmit": true,
		"strict": false,
		"skipLibCheck": true,
		"lib": ["DOM", "DOM.Iterable", "ES2021"]
	},
	"include": [
		"client/runtime.ts",
		"client/runtime/**/*.ts",
		"client/vendor/**/*.ts",
		"client/types/**/*.d.ts"
	]
}
