{
	"compilerOptions": {
		"composite": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"allowJs": false,
		"strict": false,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["node", "vite/client", "vitest/globals"]
	},
	"include": ["*.ts"],
	"exclude": ["node_modules"]
}
