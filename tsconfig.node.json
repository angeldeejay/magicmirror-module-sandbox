{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"moduleDetection": "force",
		"allowImportingTsExtensions": true,
		"allowJs": false,
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": [
		"bin/**/*.ts",
		"config/**/*.ts",
		"scripts/**/*.ts",
		"server/**/*.ts",
		"shims/**/*.ts",
		"tests/tests-runner.ts"
	]
}
